# ==============================================================
# Home Cloud Drive - Production Environment Configuration
# ==============================================================
# SECURITY WARNING: Never commit this file to version control!
# Copy .env.example to .env and configure for your environment
# ==============================================================

# =====================
# REQUIRED - Security
# =====================
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_TO_A_64_CHARACTER_HEX_STRING

# =====================
# Storage Paths
# =====================
# Where uploaded files are stored
STORAGE_PATH=/home/chetas/homecloud/storage

# Where database is stored
DATA_PATH=/home/chetas/homecloud/data

# =====================
# Storage Limits
# =====================
# Max storage per user in bytes (default: 100GB = 107374182400)
# Set to 0 for unlimited
MAX_STORAGE_BYTES=0

# =====================
# Authentication
# =====================
# JWT token expiration in minutes (default: 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Password reset token lifetime in minutes (default: 30)
PASSWORD_RESET_EXPIRE_MINUTES=30

# =====================
# CORS Origins
# =====================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://192.168.1.8:3001,http://localhost:3001

# =====================
# Registration
# =====================
# Allow new user signups (default: false for security)
ALLOW_REGISTRATION=false

# =====================
# Transactional Email / Password Reset
# =====================
# Resend API settings for forgot-password and other account emails
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=Home Cloud
RESEND_API_URL=https://api.resend.com/emails
RESEND_TIMEOUT_SECONDS=15

# Public frontend URL used in emailed reset links, e.g. https://cloud.example.com/reset-password
PASSWORD_RESET_URL=
