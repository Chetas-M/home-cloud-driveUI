# Environment Configuration
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME
DATABASE_URL=sqlite+aiosqlite:///./data/homecloud.db
STORAGE_PATH=./storage
MAX_STORAGE_BYTES=107374182400
MAX_FILE_SIZE_BYTES=1073741824
TRASH_AUTO_DELETE_DAYS=30
ACCESS_TOKEN_EXPIRE_MINUTES=1440
TWO_FACTOR_TEMP_TOKEN_EXPIRE_MINUTES=10
PASSWORD_RESET_EXPIRE_MINUTES=30
SESSION_LAST_SEEN_UPDATE_INTERVAL_SECONDS=60
TRUST_PROXY_HEADERS=false
# Allow new user signups (default: false for security)
ALLOW_REGISTRATION=false
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=Home Cloud
RESEND_API_URL=https://api.resend.com/emails
RESEND_TIMEOUT_SECONDS=15
# Optional explicit frontend reset page URL, e.g. https://cloud.example.com/reset-password
PASSWORD_RESET_URL=
