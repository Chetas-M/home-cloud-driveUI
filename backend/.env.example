# Environment Configuration
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME
DATABASE_URL=sqlite+aiosqlite:///./data/homecloud.db
STORAGE_PATH=./storage
MAX_STORAGE_BYTES=107374182400
ACCESS_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_RESET_EXPIRE_MINUTES=30
# Allow new user signups (default: false for security)
ALLOW_REGISTRATION=false
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=Home Cloud
RESEND_API_URL=https://api.resend.com/emails
RESEND_TIMEOUT_SECONDS=15
# Optional explicit frontend URL to use in reset emails, e.g. https://cloud.example.com/
PASSWORD_RESET_URL=
